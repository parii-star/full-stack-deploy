{
  "name": "full-stack-worker-api",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "npm --prefix ../web run build && rm -rf dist && cp -R ../web/dist dist",
    "predev": "npm run build:web",
    "dev": "wrangler dev --ip 0.0.0.0 --port 8787",
    "deploy": "npm run build:web && wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260518.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.20.0"
  }
}
