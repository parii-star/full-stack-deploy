# Used by docker-compose.yml (optional; defaults are provided)

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=expenses

# Optional host port bindings (local only)
WEB_HOST_PORT=8080
POSTGRES_HOST_PORT=5432

# Optional: restrict which browser origin can call the API
# (Leave empty when using the built-in Nginx reverse proxy.)
# CORS_ORIGIN=https://your-domain.com
